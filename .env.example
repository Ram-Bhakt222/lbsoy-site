# Public site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://longbeachschoolofyoga.com

# MYN handoff destination (used by CTA buttons across the site)
NEXT_PUBLIC_MYN_URL=https://myyoganetwork.com

# GoHighLevel booking calendar (used on /contact and /free-consultation)
# Pull the public calendar URL from GHL (LBSOY sub-account -> Calendars -> "LBSOY Free Consultation").
NEXT_PUBLIC_GHL_CALENDAR_URL=

# Optional: Google Site Verification + Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
